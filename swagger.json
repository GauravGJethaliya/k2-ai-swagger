{
    "swagger": "2.0",
    "info": {
        "title": "K2 AI API",
        "version": "1.0"
    },
    "host": "localhost:7050",
    "basePath": "/api",
    "schemes": [
        "http"
    ],
    "paths": {
        "/generate-summary": {
            "get": {
                "operationId": "GenerateSummary",
                "produces": [
                    "application/json"
                ],
                "parameters": [
                    {
                        "name": "name",
                        "in": "query",
                        "required": false,
                        "type": "string",
                        "description": "Name"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "status": {
                                    "type": "string"
                                },
                                "summary": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}